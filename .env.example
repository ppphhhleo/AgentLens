# Copy to .env and fill in your key. .env is gitignored.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Optional overrides
# OPENAI_BASE_URL=https://api.openai.com/v1
# AGENTLENS_OPENAI_AUTH_MODE=codex_oauth
# AGENTLENS_CODEX_AUTH_FILE=~/.codex/auth.json
# AGENTLENS_CODEX_MODEL=gpt-5.5
# ANTHROPIC_BASE_URL=

# BrowserGym MiniWoB++ static file URL.
# Clone Farama-Foundation/miniwob-plusplus first:
#   mkdir -p ~/.cache/agentlens && cd ~/.cache/agentlens && \
#     git clone --depth 1 https://github.com/Farama-Foundation/miniwob-plusplus.git
# MINIWOB_URL=file:///Users/<you>/.cache/agentlens/miniwob-plusplus/miniwob/html/miniwob/
