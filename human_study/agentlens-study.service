[Unit]
Description=AgentLens Human Study Server
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/AgentLens
ExecStart=/home/ubuntu/AgentLens/.venv/bin/python /home/ubuntu/AgentLens/human_study/server.py --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
